<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Dashboard - Pinfo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Pinfo</a>
            <div class="collapse navbar-collapse">
                <div class="d-flex ms-auto">
                    <a href="/posts/new" class="btn btn-success btn-sm me-2">+ New Post</a>
                    <% if (typeof loggedInUser !== 'undefined' && loggedInUser) { %>
                        <a href="/users/<%= loggedInUser.username %>" class="btn btn-outline-light btn-sm me-2">Profile</a>
                    <% } %>
                    <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="mb-5 text-center">
                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 100px; height: 100px; font-weight: bold; font-size: 2.5rem;">
                        <%= loggedInUser.first_name[0] %><%= loggedInUser.last_name[0] %>
                    </div>
                    <h2 class="fw-bold">My Dashboard</h2>
                    <p class="text-muted small">@<%= loggedInUser.username %></p>
                </div>
                
                <h4 class="mb-4">My Posts (All States)</h4>
                
                <% if (posts.length === 0) { %>
                    <div class="alert alert-info text-center">You haven't created any posts yet. <a href="/posts/new">Create one now!</a></div>
                <% } else { %>
                    <% posts.forEach(post => { %>
                        <div class="card post-card mb-3">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <a href="/post/<%= post._id %>" class="text-dark text-decoration-none">
                                        <h5 class="card-title fw-bold m-0"><%= post.title %></h5>
                                    </a>
                                    <% if (post.state === 'draft') { %>
                                        <span class="badge bg-warning text-dark">Draft</span>
                                    <% } else { %>
                                        <span class="badge bg-success">Published</span>
                                    <% } %>
                                </div>
                                <p class="card-text text-muted small mb-2"><%= post.content %></p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-muted"><%= new Date(post.createdAt).toLocaleDateString() %></span>
                                    <div>
                                        <!-- Edit Button attached with data attributes to fill the modal -->
                                        <button class="btn btn-sm btn-outline-primary me-1" 
                                            data-id="<%= post._id %>"
                                            data-title="<%= post.title %>"
                                            data-content="<%= post.content %>"
                                            data-tags="<%= post.tags.join(',') %>"
                                            data-state="<%= post.state %>"
                                            onclick="openEditModal(this)">Edit</button>
                                        
                                        <!-- Delete Button -->
                                        <button class="btn btn-sm btn-outline-danger" onclick="deletePost('<%= post._id %>')">Delete</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Edit Post Modal (Hidden by default) -->
    <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Edit Post</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <form id="editPostForm">
                <input type="hidden" id="edit-id">
                <div class="mb-3">
                    <label>Title</label>
                    <input type="text" id="edit-title" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label>Content</label>
                    <textarea id="edit-content" class="form-control" rows="4" required></textarea>
                </div>
                <div class="mb-3">
                    <label>Tags <small class="text-muted">(comma separated)</small></label>
                    <input type="text" id="edit-tags" class="form-control">
                </div>
                <div class="mb-3">
                    <label>Post State</label>
                    <select id="edit-state" class="form-select">
                        <option value="published">Published</option>
                        <option value="draft">Draft</option>
                    </select>
                </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary" onclick="submitEdit()">Save Changes</button>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Interactive Logic -->
    <script>
        let editModalInstance;

        // DELETE LOGIC
        async function deletePost(postId) {
            if (!confirm("Are you sure you want to delete this post? This cannot be undone.")) return;

            try {
                const response = await fetch(`/api/posts/${postId}`, {
                    method: 'DELETE',
                    credentials: 'same-origin' // Ensures user is authenticated
                });
                const result = await response.json();

                if (result.success) {
                    window.location.reload(); 
                } else {
                    alert(result.message || "Failed to delete post.");
                }
            } catch (err) {
                console.error("Error:", err);
            }
        }

        // EDIT MODAL LOGIC (Open & Fill Data)
        function openEditModal(buttonElement) {
            document.getElementById('edit-id').value = buttonElement.getAttribute('data-id');
            document.getElementById('edit-title').value = buttonElement.getAttribute('data-title');
            document.getElementById('edit-content').value = buttonElement.getAttribute('data-content');
            document.getElementById('edit-tags').value = buttonElement.getAttribute('data-tags');
            document.getElementById('edit-state').value = buttonElement.getAttribute('data-state');

            editModalInstance = new bootstrap.Modal(document.getElementById('editModal'));
            editModalInstance.show();
        }

        // SUBMIT EDIT LOGIC
        async function submitEdit() {
            const postId = document.getElementById('edit-id').value;
            const tagsInput = document.getElementById('edit-tags').value;
            const tagsArray = tagsInput ? tagsInput.split(',').map(tag => tag.trim()) : [];

            const data = {
                title: document.getElementById('edit-title').value,
                content: document.getElementById('edit-content').value,
                tags: tagsArray,
                state: document.getElementById('edit-state').value
            };

            try {
                const response = await fetch(`/api/posts/${postId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();

                if (result.success) {
                    window.location.reload();
                } else {
                    alert(result.message || result.error || "Failed to update post.");
                }
            } catch (err) {
                console.error("Error:", err);
            }
        }
    </script>
</body>
</html>