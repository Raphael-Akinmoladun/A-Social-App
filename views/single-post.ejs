<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= post.title %> - Pinfo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar (Simplified) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Pinfo</a>
            <div class="d-flex ms-auto">
                <% if (typeof loggedInUser !== 'undefined' && loggedInUser) { %>
                    <a href="/profile" class="btn btn-outline-light btn-sm me-2">Dashboard</a>
                    <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn btn-primary btn-sm">Sign In</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <a href="/" class="text-decoration-none mb-3 d-inline-block">&larr; Back to Feed</a>
                <div class="card post-card p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px; font-weight: bold; font-size: 1.4rem;">
                            <%= post.author.first_name[0] %><%= post.author.last_name[0] %>
                        </div>
                        <div>
                            <a href="/users/<%= post.author.username %>" class="author-name d-block fs-5"><%= post.author.first_name %> <%= post.author.last_name %></a>
                            <span class="text-muted">@<%= post.author.username %> • <%= new Date(post.createdAt).toLocaleDateString() %></span>
                        </div>
                    </div>
                    
                    <h2 class="fw-bold mb-3"><%= post.title %></h2>
                    <p class="fs-5 mb-4"><%= post.content %></p>
                    
                    <div class="mb-4">
                        <% post.tags.forEach(tag => { %>
                            <span class="badge bg-secondary rounded-pill me-1 fs-6">#<%= tag %></span>
                        <% }) %>
                    </div>
                    
                    <hr>
                    <h5 class="mb-3"><%= post.comment_count %> Comments</h5>
                    
                    <!-- Comments List -->
                    <% if (post.comments && post.comments.length > 0) { %>
                        <% post.comments.forEach(comment => { %>
                            <div class="mb-3 bg-light p-3 rounded">
                                <strong><%= comment.user.first_name %> <%= comment.user.last_name %>:</strong>
                                <span class="text-muted small ms-2"><%= new Date(comment.createdAt).toLocaleDateString() %></span>
                                <p class="mb-0 mt-1"><%= comment.text %></p>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-muted">No comments yet. Be the first!</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>